<?xml version="1.0" encoding="utf-8"?>
<!--
  「写一句」2x2 桌面上的传话筒
  尺寸：432 x 432 px
  类型：action (compose)
  支持深色模式：是
-->
<Widget
  version="1"
  frameRate="30"
  screenWidth="432"
  screenHeight="432"
  id="anyu_003_xieyiju"
  useVariableUpdater="DateTime"
>
  <!-- 背景：月白-天青浅渐变 -->
  <Image
    x="0" y="0"
    width="#screen_width" height="#screen_height"
    src="bg_quiet.png"
  />

  <!-- 底部波形层（半透明） -->
  <Path
    d="M0 280 Q108 260 216 275 T432 270 L432 432 L0 432 Z"
    color="#A3B8C6"
    alpha="60"
  />
  <Path
    d="M0 320 Q108 300 216 320 T432 320 L432 432 L0 432 Z"
    color="#7A93A4"
    alpha="40"
  />

  <!-- 右上角装饰小圆点组 -->
  <Group x="#screen_width - 50" y="50" alignH="right" alignV="center">
    <Circle x="-30" y="0" radius="2.5" color="#A3B8C6" alpha="100" />
    <Circle x="-15" y="0" radius="2.5" color="#A3B8C6" alpha="80" />
    <Circle x="0" y="0" radius="2.5" color="#A3B8C6" alpha="60" />
  </Group>

  <!-- 主图形：信封+心形 -->
  <Group
    x="#screen_width/2"
    y="#screen_height * 0.36"
    alignH="center" alignV="center"
  >
    <!-- 信封主体 -->
    <Rect
      x="-32" y="-26" width="64" height="44" rx="4"
      color="#FFFFFF"
      borderColor="#7A93A4"
      borderWidth="2"
    />
    <Path
      d="M-32 -23 L0 4 L32 -23"
      color="#7A93A4"
      strokeWidth="2"
    />
    <!-- 文字行 -->
    <Line
      x1="-20" y1="-2" x2="20" y2="-2"
      color="#A3B8C6" strokeWidth="1.5"
    />
    <Line
      x1="-20" y1="6" x2="14" y2="6"
      color="#A3B8C6" strokeWidth="1.5"
    />
    <Line
      x1="-20" y1="14" x2="22" y2="14"
      color="#A3B8C6" strokeWidth="1.5"
    />
    <!-- 飘出的心形 -->
    <Path
      d="M28 -22 C26 -28, 18 -28, 18 -21 C18 -28, 10 -28, 8 -22 C6 -16, 14 -10, 18 -6 C22 -10, 30 -16, 28 -22 Z"
      color="#E6D5D5"
      borderColor="#C9A8A8"
      borderWidth="1"
    />
  </Group>

  <!-- 副标题：安语·传话 -->
  <Text
    x="#screen_width/2" y="#screen_height * 0.58"
    align="center" alignV="center"
    color="#A3B8C6" size="12" alpha="180"
    text="安 语 · 传 话"
  />

  <!-- 主标题 -->
  <Text
    x="#screen_width/2" y="#screen_height * 0.66"
    align="center" alignV="center"
    color="#3B4A5C" size="28"
    text="写一句"
  />

  <!-- 引导语（轮换） -->
  <Text
    x="#screen_width/2" y="#screen_height * 0.76"
    align="center" alignV="center"
    color="#5A6B7C" size="13" alpha="200"
    text="#hintText"
    maxWidth="320"
  />

  <!-- 时间 -->
  <Text
    x="#screen_width/2" y="#screen_height - 16"
    align="center" alignV="bottom"
    color="#A3B8C6" size="9" alpha="120"
    format="%H:%M"
  />
</Widget>
